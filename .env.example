# TravelPayouts / Hotellook API
TRAVELPAYOUTS_TOKEN=your_token_here

# Server
PORT=3000
NODE_ENV=development

# CORS — set to your Webflow domain in production
# Comma-separated if multiple origins needed
ALLOWED_ORIGINS=https://outinry.webflow.io,https://outinry.com

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600
